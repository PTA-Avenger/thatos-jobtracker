@page "/jobs"

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold mb-1">Discover Jobs</h1>
            <p class="text-secondary small">Browse listings automatically aggregated by your Ryzen local scraper</p>
        </div>
    </div>

    <!-- Search / Filter Bar -->
    <div class="glass-card mb-4">
        <form @onsubmit="() => SearchJobs(0)" class="row g-3">
            <div class="col-md-4">
                <label class="glass-label">Job Title</label>
                <input type="text" class="glass-input py-2" placeholder="e.g. Software Engineer" @bind="searchTitle" />
            </div>
            <div class="col-md-4">
                <label class="glass-label">Company</label>
                <input type="text" class="glass-input py-2" placeholder="e.g. Microsoft" @bind="searchCompany" />
            </div>
            <div class="col-md-4">
                <label class="glass-label">Required Skills</label>
                <input type="text" class="glass-input py-2" placeholder="e.g. Java, Python" @bind="searchSkills" />
            </div>
            
            <div class="col-md-3">
                <label class="glass-label">Visa Sponsorship</label>
                <select class="glass-input py-2" @bind="searchVisaSelected">
                    <option value="">All</option>
                    <option value="true">Yes</option>
                    <option value="false">No</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="glass-label">Max Experience Required</label>
                <select class="glass-input py-2" @bind="searchMaxExperienceSelected">
                    <option value="">All</option>
                    <option value="0">0 Years (Grad/Entry)</option>
                    <option value="1">1 Year</option>
                    <option value="2">2 Years</option>
                    <option value="3">3 Years</option>
                    <option value="5">5 Years</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="glass-label">Source Platform</label>
                <select class="glass-input py-2" @bind="searchSource">
                    <option value="">All</option>
                    <option value="OfferZen">OfferZen</option>
                    <option value="Prosple">Prosple</option>
                    <option value="WeWorkRemotely">WeWorkRemotely</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn-gradient w-100 py-2 d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-search"></i> Search Listings
                </button>
            </div>
        </form>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center py-5">
            <div class="app-loader-spinner"></div>
        </div>
    }
    else if (jobsPage == null || jobsPage.Content.Count == 0)
    {
        <div class="glass-card text-center py-5">
            <i class="bi bi-briefcase text-secondary fs-1 mb-3"></i>
            <h3 class="h5 font-weight-bold mb-2">No Jobs Found</h3>
            <p class="text-secondary small mb-0">Try clearing your filters or check if your scraper has successfully uploaded jobs.</p>
        </div>
    }
    else
    {
        <!-- Jobs List -->
        <div class="jobs-list-container mb-4">
            @foreach (var job in jobsPage.Content)
            {
                <div class="glass-card job-row-card">
                    <div class="job-row-details">
                        <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                            <h3 class="h5 font-weight-bold m-0 text-primary">@job.Title</h3>
                            
                            @if (!string.IsNullOrEmpty(job.SourcePlatform))
                            {
                                <span class="badge bg-secondary text-dark fw-bold">@job.SourcePlatform</span>
                            }
                            
                            @if (job.IsGhostJob)
                            {
                                <span class="badge bg-danger text-white fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> Possible Ghost Job</span>
                            }

                            @if (!string.IsNullOrEmpty(job.ClosingDate))
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i> Deadline: @job.ClosingDate</span>
                            }
                            
                            @if (job.VisaSponsorship.HasValue)
                            {
                                @if (job.VisaSponsorship.Value)
                                {
                                    <span class="badge bg-success text-white"><i class="bi bi-passport me-1"></i> Visa Sponsored</span>
                                }
                                else
                                {
                                    <span class="badge bg-dark border border-secondary text-secondary"><i class="bi bi-x-circle me-1"></i> No Visa</span>
                                }
                            }
                            
                            @if (job.YearsExperienceRequired.HasValue)
                            {
                                <span class="badge bg-info text-dark"><i class="bi bi-person-workspace me-1"></i> @(job.YearsExperienceRequired.Value == 0 ? "Entry/Grad" : $"{job.YearsExperienceRequired.Value} Yrs Exp")</span>
                            }
                            
                            <span class="badge bg-dark border border-secondary text-secondary">
                                <i class="bi bi-calendar-event me-1"></i> Posted: @job.DatePosted
                            </span>
                        </div>
                        <p class="text-secondary small mb-3">
                            <span class="fw-semibold text-light me-3"><i class="bi bi-building me-1"></i> @job.Company</span>
                            <span><i class="bi bi-geo-alt me-1"></i> @job.Location</span>
                        </p>
                        
                        <!-- Skills tags -->
                        <div class="mb-3">
                            @if (!string.IsNullOrEmpty(job.Skills))
                            {
                                var skills = job.Skills.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
                                foreach (var skill in skills)
                                {
                                    <span class="skill-badge me-1">@skill.Trim()</span>
                                }
                            }
                        </div>

                        <!-- Job Description Preview (Truncated) -->
                        <div class="text-secondary small text-truncate-3" style="max-height: 50px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; white-space: normal;">
                            @job.Description
                        </div>
                    </div>

                    <div class="job-row-actions">
                        @if (trackedJobIds.Contains(job.Id))
                        {
                            <button class="btn btn-outline border-success text-success d-flex align-items-center gap-2" disabled>
                                <i class="bi bi-check2-circle"></i> Tracked
                            </button>
                        }
                        else
                        {
                            <button class="btn-gradient d-flex align-items-center gap-2" @onclick="() => TrackJobAsync(job)" disabled="@trackingLoadingIds.Contains(job.Id)">
                                @if (trackingLoadingIds.Contains(job.Id))
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                }
                                else
                                {
                                    <i class="bi bi-plus-lg"></i>
                                }
                                <span>Track Application</span>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Pagination Controls -->
        @if (jobsPage.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center glass-card py-2 px-3">
                <span class="small text-secondary">
                    Showing page @(jobsPage.Number + 1) of @jobsPage.TotalPages (@jobsPage.TotalElements listings total)
                </span>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline py-1 px-3" 
                            disabled="@(jobsPage.Number == 0)" 
                            @onclick="() => SearchJobs(jobsPage.Number - 1)">
                        <i class="bi bi-chevron-left me-1"></i> Previous
                    </button>
                    <button class="btn btn-sm btn-outline py-1 px-3" 
                            disabled="@(jobsPage.Number >= jobsPage.TotalPages - 1)" 
                            @onclick="() => SearchJobs(jobsPage.Number + 1)">
                        Next <i class="bi bi-chevron-right ms-1"></i>
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    private PaginatedResponse<Job>? jobsPage;
    private HashSet<long> trackedJobIds = new();
    private HashSet<long> trackingLoadingIds = new();
    private bool isLoading = true;

    // Search properties
    private string searchTitle = string.Empty;
    private string searchCompany = string.Empty;
    private string searchSkills = string.Empty;
    
    private string searchVisaSelected = string.Empty;
    private bool? searchVisa => string.IsNullOrEmpty(searchVisaSelected) ? null : bool.Parse(searchVisaSelected);
    
    private string searchMaxExperienceSelected = string.Empty;
    private int? searchMaxExperience => string.IsNullOrEmpty(searchMaxExperienceSelected) ? null : int.Parse(searchMaxExperienceSelected);
    
    private string searchSource = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadTrackedJobsAsync();
        await SearchJobs(0);
    }

    private async Task LoadTrackedJobsAsync()
    {
        try
        {
            var apps = await ApiService.GetApplicationsAsync();
            trackedJobIds = apps.Select(a => a.Job.Id).ToHashSet();
        }
        catch (Exception) { }
    }

    private async Task SearchJobs(int pageNumber)
    {
        isLoading = true;
        try
        {
            jobsPage = await ApiService.GetJobsAsync(
                string.IsNullOrWhiteSpace(searchTitle) ? null : searchTitle.Trim(),
                string.IsNullOrWhiteSpace(searchCompany) ? null : searchCompany.Trim(),
                string.IsNullOrWhiteSpace(searchSkills) ? null : searchSkills.Trim(),
                searchVisa,
                searchMaxExperience,
                string.IsNullOrWhiteSpace(searchSource) ? null : searchSource.Trim(),
                pageNumber, 10
            );
        }
        catch (Exception) { }
        finally
        {
            isLoading = false;
        }
    }

    private async Task TrackJobAsync(Job job)
    {
        trackingLoadingIds.Add(job.Id);
        StateHasChanged();

        try
        {
            var app = await ApiService.CreateApplicationAsync(job.Id, "To Apply");
            if (app != null)
            {
                trackedJobIds.Add(job.Id); // Add to local tracked list
            }
        }
        catch (Exception) { }
        finally
        {
            trackingLoadingIds.Remove(job.Id);
            StateHasChanged();
        }
    }
}
