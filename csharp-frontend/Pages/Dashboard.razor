@page "/dashboard"

<div class="container-fluid p-0">
    <div class="mb-4">
        <h1 class="h3 font-weight-bold mb-1">Analytics Dashboard</h1>
        <p class="text-secondary small">Real-time metrics and funnel tracking for your job hunt</p>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center py-5">
            <div class="app-loader-spinner"></div>
        </div>
    }
    else if (stats == null || stats.TotalApplications == 0)
    {
        <div class="glass-card text-center py-5">
            <i class="bi bi-graph-up text-secondary fs-1 mb-3"></i>
            <h3 class="h5 font-weight-bold mb-2">No Data Available</h3>
            <p class="text-secondary small mb-0">Track applications on your board to populate the dashboard metrics.</p>
        </div>
    }
    else
    {
        <!-- Stats Row -->
        <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
            <div class="glass-card stat-box ToApply">
                <div class="stat-label">To Apply</div>
                <div class="stat-value text-muted" style="color: #a3a3a3 !important;">@GetStatusCount("To Apply")</div>
            </div>
            <div class="glass-card stat-box Applied">
                <div class="stat-label">Applied</div>
                <div class="stat-value text-primary" style="color: var(--color-applied) !important;">@GetStatusCount("Applied")</div>
            </div>
            <div class="glass-card stat-box OA">
                <div class="stat-label">Assessments (OA)</div>
                <div class="stat-value text-info" style="color: #06b6d4 !important;">@GetStatusCount("Online Assessment")</div>
            </div>
            <div class="glass-card stat-box Interview">
                <div class="stat-label">Interviews</div>
                <div class="stat-value text-warning" style="color: var(--color-interview) !important;">@GetStatusCount("Interview")</div>
            </div>
            <div class="glass-card stat-box Offer">
                <div class="stat-label">Offers</div>
                <div class="stat-value text-success" style="color: var(--color-offer) !important;">@GetStatusCount("Offer")</div>
            </div>
            <div class="glass-card stat-box Rejected">
                <div class="stat-label">Rejected</div>
                <div class="stat-value text-danger" style="color: var(--color-rejected) !important;">@GetStatusCount("Rejected")</div>
            </div>
        </div>

        <!-- Deadline Engine Row -->
        <div class="glass-card mb-4">
            <h2 class="h5 font-weight-bold mb-3"><i class="bi bi-alarm-fill text-warning me-2"></i> SDE Deadline Engine</h2>
            <p class="text-secondary small mb-4">Track upcoming closing dates for your SDE applications to make sure you submit in time.</p>
            @if (deadlineApps.Count == 0)
            {
                <div class="text-center text-muted small py-4">
                    No upcoming deadlines tracked.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0" style="background: rgba(255,255,255,0.01); border-color: rgba(255,255,255,0.05);">
                        <thead>
                            <tr class="text-secondary small">
                                <th>Role</th>
                                <th>Company</th>
                                <th>Source</th>
                                <th>Status</th>
                                <th>Closing Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var app in deadlineApps)
                            {
                                <tr>
                                    <td class="align-middle fw-semibold text-light text-truncate" style="max-width: 180px;">@app.Job.Title</td>
                                    <td class="align-middle text-secondary">@app.Job.Company</td>
                                    <td class="align-middle"><span class="badge bg-secondary text-dark">@app.Job.SourcePlatform</span></td>
                                    <td class="align-middle">
                                        <span class="badge @(GetStatusBadgeClass(app.Status))">@app.Status</span>
                                    </td>
                                    <td class="align-middle fw-bold text-warning">
                                        <i class="bi bi-hourglass-split me-1"></i> @app.Job.ClosingDate
                                    </td>
                                    <td class="align-middle">
                                        <button class="btn btn-sm btn-outline-secondary py-0 px-2 text-light" style="border-radius: 4px; background: rgba(255,255,255,0.05);" @onclick="() => GoToBoard()">
                                            View Board
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="row g-4">
            <!-- Funnel Conversion Rates -->
            <div class="col-lg-6">
                <div class="glass-card h-100">
                    <h2 class="h5 font-weight-bold mb-4"><i class="bi bi-funnel-fill text-info me-2"></i> Application Funnel</h2>
                    
                    @{
                        var total = stats.TotalApplications;
                        var toApply = GetStatusCount("To Apply");
                        var applied = GetStatusCount("Applied");
                        var oa = GetStatusCount("Online Assessment");
                        var interviews = GetStatusCount("Interview");
                        var offers = GetStatusCount("Offer");

                        double appliedRate = total > 0 ? (double)(applied + oa + interviews + offers) / total * 100 : 0;
                        double oaRate = (applied + oa + interviews + offers) > 0 ? (double)(oa + interviews + offers) / (applied + oa + interviews + offers) * 100 : 0;
                        double interviewRate = (oa + interviews + offers) > 0 ? (double)(interviews + offers) / (oa + interviews + offers) * 100 : 0;
                        double offerRate = interviews > 0 ? (double)offers / interviews * 100 : 0;
                    }

                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-2 small">
                            <span class="text-secondary">Application Submission Rate (To Apply → Applied)</span>
                            <span class="text-light fw-semibold">@appliedRate.ToString("0")%</span>
                        </div>
                        <div class="progress" style="height: 10px; background: rgba(255,255,255,0.05); border-radius: 6px;">
                            <div class="progress-bar" role="progressbar" style="width: @(appliedRate)%; background: linear-gradient(135deg, #3b82f6, #06b6d4); border-radius: 6px;"></div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-2 small">
                            <span class="text-secondary">Assessment Invite Rate (Applied → OA)</span>
                            <span class="text-light fw-semibold">@oaRate.ToString("0")%</span>
                        </div>
                        <div class="progress" style="height: 10px; background: rgba(255,255,255,0.05); border-radius: 6px;">
                            <div class="progress-bar" role="progressbar" style="width: @(oaRate)%; background: linear-gradient(135deg, #06b6d4, #10b981); border-radius: 6px;"></div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-2 small">
                            <span class="text-secondary">Interview Conversion Rate (OA → Interview)</span>
                            <span class="text-light fw-semibold">@interviewRate.ToString("0")%</span>
                        </div>
                        <div class="progress" style="height: 10px; background: rgba(255,255,255,0.05); border-radius: 6px;">
                            <div class="progress-bar" role="progressbar" style="width: @(interviewRate)%; background: linear-gradient(135deg, #f59e0b, #eab308); border-radius: 6px;"></div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-2 small">
                            <span class="text-secondary">Offer Success Rate (Interview → Offer)</span>
                            <span class="text-light fw-semibold">@offerRate.ToString("0")%</span>
                        </div>
                        <div class="progress" style="height: 10px; background: rgba(255,255,255,0.05); border-radius: 6px;">
                            <div class="progress-bar" role="progressbar" style="width: @(offerRate)%; background: linear-gradient(135deg, #10b981, #059669); border-radius: 6px;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Activity Log -->
            <div class="col-lg-6">
                <div class="glass-card h-100">
                    <h2 class="h5 font-weight-bold mb-4"><i class="bi bi-clock-history text-purple me-2"></i> Funnel Activity Log</h2>
                    <div class="sub-list" style="max-height: 300px; overflow-y: auto;">
                        @if (stats.ApplicationTimeline == null || stats.ApplicationTimeline.Count == 0)
                        {
                            <div class="text-center text-muted small py-5">
                                No activity recorded.
                            </div>
                        }
                        else
                        {
                            @foreach (var day in stats.ApplicationTimeline.OrderByDescending(d => d.Key).Take(7))
                            {
                                <div class="sub-item">
                                    <span class="sub-item-text"><i class="bi bi-calendar-check me-2 text-info"></i> Tracked Job applications</span>
                                    <span class="badge bg-dark border border-secondary px-3 py-1 text-primary">@day.Value active</span>
                                    <span class="sub-item-meta">@day.Key</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DashboardStats? stats;
    private List<Application> deadlineApps = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        isLoading = true;
        try
        {
            stats = await ApiService.GetDashboardStatsAsync();
            var apps = await ApiService.GetApplicationsAsync();
            deadlineApps = apps
                .Where(a => !string.IsNullOrEmpty(a.Job.ClosingDate))
                .OrderBy(a => {
                    if (DateTime.TryParse(a.Job.ClosingDate, out var date))
                        return date;
                    return DateTime.MaxValue;
                })
                .ToList();
        }
        catch (Exception) { }
        finally
        {
            isLoading = false;
        }
    }

    private long GetStatusCount(string status)
    {
        if (stats != null && stats.StatusDistribution.TryGetValue(status, out var val))
        {
            return val;
        }
        return 0;
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "To Apply" => "bg-secondary text-light",
            "Applied" => "bg-primary text-white",
            "Online Assessment" => "bg-info text-dark",
            "Interview" => "bg-warning text-dark",
            "Offer" => "bg-success text-white",
            "Rejected" => "bg-danger text-white",
            _ => "bg-dark text-secondary border border-secondary"
        };
    }

    private void GoToBoard()
    {
        Navigation.NavigateTo("/");
    }
}
